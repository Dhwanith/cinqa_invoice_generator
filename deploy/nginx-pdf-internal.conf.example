# Initial HTTP server block for Certbot bootstrap. Run `certbot --nginx -d pdf-internal.cinqa.space` after enabling this site.
server {
    listen 80;
    server_name pdf-internal.cinqa.space;

    client_max_body_size 10m;

    auth_basic "Cinqa PDF Service";
    auth_basic_user_file /etc/nginx/.htpasswd-cinqa-pdf;

    location / {
        proxy_pass http://127.0.0.1:8001;
        proxy_http_version 1.1;
        proxy_set_header Host $host;
        proxy_set_header X-Real-IP $remote_addr;
        proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
        proxy_set_header X-Forwarded-Proto $scheme;
    }
}